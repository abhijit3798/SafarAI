# SafarAI Environment Variables
# Duplicate this file to '.env' and fill in your credentials.

# (Optional) Direct client-side Gemini API key fallback.
# If omitted, users can still input their API keys directly via the Profile Settings tab,
# or use the built-in mock database to test Indian destinations.
VITE_GEMINI_API_KEY=your_gemini_api_key_here
